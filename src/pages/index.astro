---
const title = 'template-astro'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Astro starter template" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main>
      <h1>Hello, World!</h1>
      <p>Get started by editing <code>src/pages/index.astro</code></p>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: system-ui, sans-serif;
    line-height: 1.6;
  }

  body {
    margin: 0;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  main {
    text-align: center;
    padding: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  code {
    background: #f4f4f5;
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
</style>
