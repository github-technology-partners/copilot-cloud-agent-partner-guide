<section class="mb-6" id="quick-reference">
  <h2>Appendix A. Quick reference</h2>

  <h3>Endpoints</h3>
  <div class="highlight">
    <pre><code>POST   /agents/repos/{'{owner}'}/{'{repo}'}/tasks
GET    /agents/repos/{'{owner}'}/{'{repo}'}/tasks
GET    /agents/repos/{'{owner}'}/{'{repo}'}/tasks/{'{task_id}'}
GET    /agents/tasks</code></pre>
  </div>

  <h3>Required headers</h3>
  <div class="highlight">
    <pre><code>Accept: application/vnd.github+json
X-GitHub-Api-Version: 2022-11-28
Authorization: Bearer &lt;USER_TO_SERVER_TOKEN&gt;</code></pre>
  </div>

  <h3>Minimum prerequisites checklist</h3>
  <ul class="contains-task-list">
    <li class="task-list-item"><input type="checkbox" disabled /> Connected GitHub user has Copilot Business or Copilot Enterprise.</li>
    <li class="task-list-item"><input type="checkbox" disabled /> Cloud agent enabled at the org (and not opted out at the repo).</li>
    <li class="task-list-item"><input type="checkbox" disabled /> Connected user has write access to the target repository.</li>
    <li class="task-list-item"><input type="checkbox" disabled /> Partner holds a valid, non-expired user-to-server token for that user.</li>
  </ul>
</section>

